{
  "name": "chat-agent-app",
  "private": true,
  "version": "0.5.0",
  "description": "栖言 - 本地优先的 Windows AI 工作台",
  "author": "why",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/why1101-why/QiyanChatAgent.git"
  },
  "homepage": "https://github.com/why1101-why/QiyanChatAgent#readme",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite --host 127.0.0.1 --port 1420 --strictPort",
    "dev:electron": "wait-on http://127.0.0.1:1420 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:1420 electron .",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "desktop:dir": "npm run build && electron-builder --dir",
    "desktop:build": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@vueuse/core": "^13.5.0",
    "dompurify": "^3.2.6",
    "lucide-vue-next": "^0.468.0",
    "marked": "^15.0.12",
    "pdfjs-dist": "^5.3.93",
    "pinia": "^3.0.3",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vue-tsc": "^3.0.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.chatagent.desktop",
    "productName": "Qiyan",
    "asar": true,
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.png",
      "artifactName": "Qiyan-${version}-Windows-${arch}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "栖言 Qiyan"
    }
  }
}
